{
  "functions": {
    "api/og-proxy.ts": {
      "includeFiles": "dist/index.html"
    }
  },
  "rewrites": [
    {
      "source": "/@:handle",
      "destination": "/api/og-proxy"
    },
    {
      "source": "/l/:slug",
      "destination": "/api/og-proxy"
    },
    {
      "source": "/tip-success",
      "destination": "/index.html"
    },
    {
      "source": "/fan",
      "destination": "/index.html"
    },
    {
      "source": "/fan/signup",
      "destination": "/index.html"
    },
    {
      "source": "/auth",
      "destination": "/index.html"
    },
    {
      "source": "/onboarding",
      "destination": "/index.html"
    },
    {
      "source": "/contact",
      "destination": "/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/index.html"
    },
    {
      "source": "/terms",
      "destination": "/index.html"
    },
    {
      "source": "/cookies",
      "destination": "/index.html"
    },
    {
      "source": "/:handle",
      "destination": "/api/og-proxy"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
