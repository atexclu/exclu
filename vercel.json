{
  "functions": {
    "api/og-proxy.ts": {
      "includeFiles": "dist/index.html"
    }
  },
  "rewrites": [
    {
      "source": "/@:handle",
      "destination": "/api/og-proxy"
    },
    {
      "source": "/l/:slug",
      "destination": "/api/og-proxy"
    },
    {
      "source": "/:handle",
      "destination": "/api/og-proxy"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
