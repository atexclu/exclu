  "crons": [
    {
      "path": "/api/cron/drain-campaigns",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/rebill-subscriptions",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/reconcile-payments",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/mature-pending-balance",
      "schedule": "30 8 * * *"
    }
  ],
  "headers": [
    {
      "source": "/149e9513-01fa-4fb0-aad4-566afd725d1b/2d206a39-8ed7-437e-a3be-862e0f06eea3/:path*",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ],
